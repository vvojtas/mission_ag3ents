# OpenRouter
ROUTER_API_KEY=your_openrouter_key_here

# AI Devs Platform
HUB_API_KEY=your_hub_api_key_here
HUB_API_URL=https://api.example.com
# Default task code for hub_post_answer / HubClient.post_answer when task_name is omitted
# HUB_TASK_NAME=your_task_code

# REST server bind (optional; used by task_03)
# HOST=127.0.0.1
# PORT=8000

# Dashboard WebSocket (optional; default path is the implementation)
# DASHBOARD_WS_URL=ws://127.0.0.1:8765/dashboard/ws

# MCP filesystem workspace (optional; defaults to repo root)
# MCP_WORKSPACE_ROOT=D:\ai\repos\mission_ag3ents
